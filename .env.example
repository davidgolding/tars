# The Signal number that the bot uses to send/receive messages (e.g., +1234567890)
BOT_SIGNAL_NUMBER=

# The Signal number of the single allowed user (e.g., +1098765432)
TARGET_SIGNAL_NUMBER=

# Optional Signal group name for Tars to listen and reply in
TARGET_SIGNAL_GROUP=

# Path to the directory containing Tars agent prompts (like SYSTEM.md)
AGENT_PROMPTS_PATH=agent/

# Provider selection (options: 'gemini-cli', 'gemini-api', default: 'gemini-cli')
LLM_PROVIDER=gemini-cli

# Max number of AI iterations before cutoff - prevents overloading LLM requests
LLM_MAX_ITERATIONS=35

# Gemini API key (optional, uses CLI provider if empty)
LLM_API_KEY=

# Gemini API model
LLM_API_MODEL=google/gemini-flash-latest

# Gemini Lite model
LLM_API_LITE_MODEL=google/gemini-flash-lite-latest

# Same as Gemini API key in most instances
GOOGLE_GENERATIVE_AI_API_KEY=

# Prevent Mastra from collecting anonymous user info
MASTRA_TELEMETRY_DISABLED=1 mastra dev

# The absolute path to the `public` folder in project root
WORKSPACE_PATH=

# Any paths on the file system accessible to the agent separated by commas
WORKSPACE_ALLOWED_PATHS=

# Jina.ai API key for web fetch and web search capabilities
JINA_API_KEY=