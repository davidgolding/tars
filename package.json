{
    "name": "tars",
    "version": "1.0.0",
    "description": "A lean, secure, local-first AI agent using Signal and Gemini",
    "type": "module",
    "scripts": {
        "dev": "tsx src/index.ts",
        "dev:mastra": "mastra dev",
        "clean": "tsx src/reset.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "setup": "tsx src/setup.ts",
        "daemon:start": "launchctl load ~/Library/LaunchAgents/com.davidgolding.tars.plist",
        "daemon:stop": "launchctl unload ~/Library/LaunchAgents/com.davidgolding.tars.plist",
        "daemon:restart": "pnpm run daemon:stop && pnpm run build && pnpm run daemon:start",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@ai-sdk/google": "^3.0.30",
        "@google/genai": "^1.42.0",
        "@inquirer/prompts": "^8.2.1",
        "@mastra/core": "^1.5.0",
        "@mastra/libsql": "^1.5.0",
        "@mastra/loggers": "^1.0.2",
        "@mastra/memory": "^1.4.0",
        "@mastra/observability": "^1.2.0",
        "@mozilla/readability": "^0.6.0",
        "@types/cheerio": "^1.0.0",
        "@types/jsdom": "^27.0.0",
        "@types/mozilla-readability": "^0.2.1",
        "@types/turndown": "^5.0.6",
        "better-sqlite3": "^12.6.2",
        "chalk": "^5.6.2",
        "cheerio": "^1.2.0",
        "dotenv": "^16.6.1",
        "duck-duck-scrape": "^2.2.7",
        "duckduckgo-search": "^1.0.7",
        "google-it": "^1.6.4",
        "jsdom": "^28.1.0",
        "mastra": "^1.3.2",
        "playwright": "^1.58.2",
        "remove-markdown": "^0.6.3",
        "signal-cli": "^0.13.19",
        "turndown": "^7.2.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^20.19.33",
        "@types/remove-markdown": "^0.3.4",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}